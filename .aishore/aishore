cmd_groom() {
    require_tool jq

    local mode="bugs"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --backlog) mode="backlog"; shift ;;
            *) log_error "Unknown option: $1"; return 1 ;;
        esac
    done

    acquire_lock
    load_config
    cd "$PROJECT_ROOT"

    local agent
    if [[ "$mode" == "backlog" ]]; then
        log_header "Product Owner: Backlog Grooming"
        agent="product-owner"
    else
        log_header "Tech Lead: Bugs/Tech Debt Grooming"
        agent="tech-lead"
    fi

    # --- Pre-launch summary ---
    print_groom_summary

    local context_args="@$BACKLOG_DIR/backlog.json @$BACKLOG_DIR/bugs.json"
    local recent_sprints; recent_sprints=$(recent_sprints_file 20)
    [[ -n "$recent_sprints" ]] && context_args="$context_args $recent_sprints"

    # Snapshot backlog state for progress tracking
    local snap_before
    snap_before=$(snapshot_backlogs)

    # Snapshot existing items so we can protect them from groomer overwrites
    local groom_snap_dir
    groom_snap_dir=$(mktemp -d)
    for f in "${BACKLOG_FILES[@]}"; do
        [[ -f "$BACKLOG_DIR/$f" ]] && cp "$BACKLOG_DIR/$f" "$groom_snap_dir/$f"
    done

    log_info "Running $agent agent..."
    echo ""

    GROOM_MONITOR=true run_agent "$agent" "groom" "$MODEL_FAST" "$context_args"

    # Protect pre-existing items from groomer modifications/deletions
    protect_items_from_groom "$groom_snap_dir"

    # Enforce groom limits (max items, min priority)
    enforce_groom_limits "$groom_snap_dir"
    rm -rf "$groom_snap_dir"

    # --- Post-groom diff ---
    print_groom_diff "$snap_before"

    if ! check_result; then
        exit 1
    fi
}

# Print a rich summary of backlog state before grooming
print_groom_summary() {
    local backlog_file="$BACKLOG_DIR/backlog.json"
    local bugs_file="$BACKLOG_DIR/bugs.json"

    log_subheader "Current Status"

    # Status counts
    if [[ -f "$backlog_file" ]]; then
        echo "  Features: $(count_by_status "$backlog_file" "todo") todo, $(count_by_status "$backlog_file" "in-progress") in-progress, $(count_by_status "$backlog_file" "done") done"
    fi
    if [[ -f "$bugs_file" ]]; then
        echo "  Bugs:     $(count_by_status "$bugs_file" "todo") todo, $(count_by_status "$bugs_file" "in-progress") in-progress, $(count_by_status "$bugs_file" "done") done"
    fi

    # Ready buffer
    local ready_backlog ready_bugs
    ready_backlog=$(count_ready_items "$backlog_file")
    ready_bugs=$(count_ready_items "$bugs_file")
    echo ""
    echo "  Ready for sprint: $((ready_backlog + ready_bugs)) ($ready_backlog features, $ready_bugs bugs)"

    # Priority breakdown — highlight must/should items that need grooming
    local has_highlights=false
    for f in "$backlog_file" "$bugs_file"; do
        [[ -f "$f" ]] || continue
        local highlights
        highlights=$(jq -r '
            .items[]
            | select((.priority == "must" or .priority == "should") and (.readyForSprint != true) and ((.status // "todo") != "done"))
            | "  \(.priority | ascii_upcase)  \(.id): \(.title)"
        ' "$f" 2>/dev/null)
        if [[ -n "$highlights" ]]; then
            if [[ "$has_highlights" == "false" ]]; then
                echo ""
                log_subheader "High Priority — Not Yet Ready"
                has_highlights=true
            fi
            echo "$highlights"
        fi
    done

    if [[ "$has_highlights" == "false" ]]; then
        # Show a note if everything high-priority is already groomed
        local must_should_total=0
        for f in "$backlog_file" "$bugs_file"; do
            [[ -f "$f" ]] || continue
            local count
            count=$(jq '[.items[] | select((.priority == "must" or .priority == "should") and ((.status // "todo") != "done"))] | length' "$f" 2>/dev/null || echo 0)
            must_should_total=$((must_should_total + count))
        done
        if [[ "$must_should_total" -gt 0 ]]; then
            echo ""
            log_success "All $must_should_total must/should items are already sprint-ready"
        fi
    fi

    echo ""
}

# Protect pre-existing items from groomer overwrites.
# Compares post-groom backlogs against the pre-groom snapshot.
# Restores any items that were modified or deleted by the groomer.
# Only groomer-added NEW items (IDs not in the snapshot) are kept.
protect_items_from_groom() {
    local snap_dir="$1"
    local restored=0 deleted_restored=0

    for f in "${BACKLOG_FILES[@]}"; do
        local snap_file="$snap_dir/$f"
        local live_file="$BACKLOG_DIR/$f"
        [[ -f "$snap_file" ]] || continue
        [[ -f "$live_file" ]] || continue

        # Get list of IDs that existed before grooming
        local old_ids
        old_ids=$(jq -r '.items[].id' "$snap_file" 2>/dev/null)
        [[ -z "$old_ids" ]] && continue

        # For each pre-existing ID, check if it was modified or deleted
        local id
        while IFS= read -r id; do
            [[ -z "$id" ]] && continue

            # Get the original item
            local original
            original=$(jq -c --arg id "$id" '.items[] | select(.id == $id)' "$snap_file" 2>/dev/null)
            [[ -z "$original" ]] && continue

            # Check if this item still exists in the live file
            local current
            current=$(jq -c --arg id "$id" '.items[] | select(.id == $id)' "$live_file" 2>/dev/null)

            if [[ -z "$current" ]]; then
                # Item was deleted by groomer — restore it
                local tmp
                tmp=$(jq --argjson item "$original" '.items += [$item]' "$live_file")
                printf '%s\n' "$tmp" > "$live_file"
                deleted_restored=$((deleted_restored + 1))
            elif [[ "$current" != "$original" ]]; then
                # Item was modified by groomer — only allow safe field changes
                # Safe: readyForSprint, groomedAt, groomedNotes, priority
                # Unsafe: title, intent, description, steps, acceptanceCriteria, id
                local was_modified
                was_modified=$(jq -n --argjson old "$original" --argjson new "$current" '
                    ($old.title != $new.title) or
                    ($old.intent != $new.intent) or
                    ($old.description != $new.description) or
                    ($old.steps != $new.steps) or
                    ($old.acceptanceCriteria != $new.acceptanceCriteria)
                ')
                if [[ "$was_modified" == "true" ]]; then
                    # Restore original item content but keep groomer's safe fields
                    local merged
                    merged=$(jq -n --argjson old "$original" --argjson new "$current" '
                        $old
                        | .readyForSprint = ($new.readyForSprint // $old.readyForSprint)
                        | .groomedAt = ($new.groomedAt // $old.groomedAt)
                        | .groomedNotes = ($new.groomedNotes // $old.groomedNotes)
                        | .priority = ($new.priority // $old.priority)
                    ')
                    local tmp
                    tmp=$(jq --arg id "$id" --argjson item "$merged" '
                        .items = [.items[] | if .id == $id then $item else . end]
                    ' "$live_file")
                    printf '%s\n' "$tmp" > "$live_file"
                    restored=$((restored + 1))
                fi
            fi
        done <<< "$old_ids"
    done

    local total=$((restored + deleted_restored))
    if [[ "$total" -gt 0 ]]; then
        log_warning "Groomer protection: restored $total pre-existing item(s) ($deleted_restored deleted, $restored modified)"
    fi
}

# Capture a snapshot of backlog item counts/ready state for diff
snapshot_backlogs() {
    local backlog_file="$BACKLOG_DIR/backlog.json"
    local bugs_file="$BACKLOG_DIR/bugs.json"
    local ready_f=0 ready_b=0 total_f=0 total_b=0
    [[ -f "$backlog_file" ]] && { ready_f=$(count_ready_items "$backlog_file"); total_f=$(count_items "$backlog_file"); }
    [[ -f "$bugs_file" ]] && { ready_b=$(count_ready_items "$bugs_file"); total_b=$(count_items "$bugs_file"); }
    echo "$ready_f $ready_b $total_f $total_b"
}

# Enforce groom limits: max items and min priority.
# Removes new items that exceed the cap or fall below the priority threshold.
# Sets GROOM_ITEMS_ADDED and GROOM_ITEMS_SKIPPED for summary reporting.
GROOM_ITEMS_ADDED=0
GROOM_ITEMS_SKIPPED=0
enforce_groom_limits() {
    local snap_dir="$1"
    local max_items="$GROOM_MAX_ITEMS"
    local min_priority="$GROOM_MIN_PRIORITY"
    GROOM_ITEMS_ADDED=0
    GROOM_ITEMS_SKIPPED=0

    # Priority rank: must=0, should=1, could=2, future=3
    local -A prio_rank=([must]=0 [should]=1 [could]=2 [future]=3)
    local min_rank="${prio_rank[$min_priority]:-1}"

    # Global kept counter — max_items applies across all files
    local global_kept=0

    for f in "${BACKLOG_FILES[@]}"; do
        local snap_file="$snap_dir/$f"
        local live_file="$BACKLOG_DIR/$f"
        [[ -f "$snap_file" ]] || continue
        [[ -f "$live_file" ]] || continue

        # Get IDs that existed before grooming
        local old_ids
        old_ids=$(jq -r '.items[].id' "$snap_file" 2>/dev/null || true)

        # Get new items (IDs not in the snapshot)
        local new_items_json
        if [[ -n "$old_ids" ]]; then
            local old_ids_array
            old_ids_array=$(printf '%s\n' "$old_ids" | jq -R . | jq -s .)
            new_items_json=$(jq --argjson old "$old_ids_array" \
                '[.items[] | select(.id as $id | $old | index($id) | not)]' "$live_file" 2>/dev/null)
        else
            new_items_json=$(jq '.items' "$live_file" 2>/dev/null)
        fi

        local new_count
        new_count=$(printf '%s' "$new_items_json" | jq 'length' 2>/dev/null || echo 0)
        [[ "$new_count" -eq 0 ]] && continue

        # Filter out items below min priority
        local removed_ids=()
        local i
        for ((i = 0; i < new_count; i++)); do
            local item_id item_prio
            item_id=$(printf '%s' "$new_items_json" | jq -r ".[$i].id")
            item_prio=$(printf '%s' "$new_items_json" | jq -r ".[$i].priority // \"could\"")
            local item_rank="${prio_rank[$item_prio]:-2}"

            if [[ "$item_rank" -gt "$min_rank" ]]; then
                # Below threshold — remove
                removed_ids+=("$item_id")
                log_info "Groom limit: skipped $item_id (priority: $item_prio, below $min_priority threshold)"
            elif [[ "$global_kept" -ge "$max_items" ]]; then
                # Over global cap — remove
                removed_ids+=("$item_id")
                log_info "Groom limit: skipped $item_id (exceeded max $max_items items)"
            else
                global_kept=$((global_kept + 1))
            fi
        done

        GROOM_ITEMS_SKIPPED=$((GROOM_ITEMS_SKIPPED + ${#removed_ids[@]}))

        # Remove filtered items from the live file
        if [[ ${#removed_ids[@]} -gt 0 ]]; then
            local ids_to_remove
            ids_to_remove=$(printf '%s\n' "${removed_ids[@]}" | jq -R . | jq -s .)
            local tmp
            tmp=$(jq --argjson rm "$ids_to_remove" \
                '.items = [.items[] | select(.id as $id | $rm | index($id) | not)]' "$live_file")
            printf '%s\n' "$tmp" > "$live_file"
        fi
    done

    GROOM_ITEMS_ADDED="$global_kept"
}

# Show what changed after grooming
print_groom_diff() {
    local before="$1"
    local snap_after
    snap_after=$(snapshot_backlogs)

    local rb_before rb_after rf_before rf_after tf_before tf_after tb_before tb_after
    read -r rf_before rb_before tf_before tb_before <<< "$before"
    read -r rf_after rb_after tf_after tb_after <<< "$snap_after"

    local ready_before=$((rf_before + rb_before))
    local ready_after=$((rf_after + rb_after))
    local total_before=$((tf_before + tb_before))
    local total_after=$((tf_after + tb_after))

    echo ""
    log_subheader "Grooming Results"

    local new_items=$((total_after - total_before))
    local new_ready=$((ready_after - ready_before))

    if [[ "$new_items" -gt 0 ]]; then
        log_success "$new_items new item(s) added"
    fi
    if [[ "$GROOM_ITEMS_SKIPPED" -gt 0 ]]; then
        log_info "$GROOM_ITEMS_SKIPPED item(s) skipped by groom limits (max=$GROOM_MAX_ITEMS, min_priority=$GROOM_MIN_PRIORITY)"
    fi
    if [[ "$new_ready" -gt 0 ]]; then
        log_success "$new_ready item(s) moved to sprint-ready"
    elif [[ "$new_ready" -eq 0 && "$new_items" -eq 0 ]]; then
        log_info "No changes to item counts"
    fi

    echo "  Ready: $ready_before → $ready_after  |  Total: $total_before → $total_after"
    if [[ "$GROOM_ITEMS_ADDED" -gt 0 || "$GROOM_ITEMS_SKIPPED" -gt 0 ]]; then
        echo "  Added: $GROOM_ITEMS_ADDED  |  Skipped: $GROOM_ITEMS_SKIPPED"
    fi
}

