# Truncate file content to last OUTPUT_TRUNCATE_LINES lines, prepending notice if truncated.
# Usage: result=$(truncate_output "$tmpfile")
truncate_output() {
    local file="$1"
    local total_lines
    total_lines=$(wc -l < "$file" 2>/dev/null || echo 0)
    local output
    output=$(tail -n "$OUTPUT_TRUNCATE_LINES" "$file" 2>/dev/null || true)
    if [[ "$total_lines" -gt "$OUTPUT_TRUNCATE_LINES" ]]; then
        output="[... output truncated, showing last $OUTPUT_TRUNCATE_LINES of $total_lines lines]"$'\n'"$output"
    fi
    printf '%s' "$output"
}

# Run a command with optional timeout, capturing output to a file.
# Usage: run_validated_command <command_string> <output_file>
# Returns: 0 on success, 1 on failure. Output is written to output_file.
run_validated_command() {
    local cmd="$1"
    local outfile="$2"
    if command -v timeout &>/dev/null; then
        timeout "$VALIDATE_TIMEOUT" bash -c "$cmd" >"$outfile" 2>&1
    else
        bash -c "$cmd" >"$outfile" 2>&1
    fi
}

restore_stash() {
    local pop_output
    if pop_output=$(git stash pop 2>&1); then
        return 0
    fi
    # Show the git error output (conflicts, etc.)
    [[ -n "$pop_output" ]] && echo "$pop_output"
    log_warning "Failed to restore stashed changes (likely due to conflicts)"
    local stash_contents
    stash_contents=$(git stash show 2>/dev/null) || true
    if [[ -n "$stash_contents" ]]; then
        log_warning "Stashed files:"
        echo "$stash_contents"
    fi
    log_warning "To resolve: run 'git stash show' to see files, then 'git stash pop' and fix conflicts"
    return 1
}

