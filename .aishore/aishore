print_batch_summary() {
    local batch_start="$1"
    local -n _results=$2
    local -n _items=$3
    local -n _times=$4
    local -n _failed_ids=$5
    local -n _skipped=$6

    local batch_elapsed=$(( $(date +%s) - batch_start ))
    local total=${#_results[@]}
    local total_passed=0
    local total_failed=0

    for r in "${_results[@]}"; do
        if [[ "$r" == "pass" ]]; then
            total_passed=$((total_passed + 1))
        else
            total_failed=$((total_failed + 1))
        fi
    done

    echo ""
    log_header "Batch Summary"
    printf "  %-8s %-12s %-8s %s\n" "Sprint" "Item" "Status" "Elapsed"
    printf "  %-8s %-12s %-8s %s\n" "------" "----" "------" "-------"

    for ((idx=0; idx<total; idx++)); do
        local status_display
        if [[ "${_results[$idx]}" == "pass" ]]; then
            status_display="${GREEN}pass${NC}"
        else
            status_display="${RED}fail${NC}"
        fi
        local mins=$(( _times[idx] / 60 ))
        local secs=$(( _times[idx] % 60 ))
        printf "  %-8s %-12s " "$((idx + 1))" "${_items[$idx]}"
        echo -e "${status_display}     ${mins}m${secs}s"
    done

    printf "  %-8s %-12s %-8s %s\n" "------" "----" "------" "-------"
    local total_mins=$(( batch_elapsed / 60 ))
    local total_secs=$(( batch_elapsed % 60 ))
    local skipped_count=${#_skipped[@]}
    printf "  Passed: %d  Failed: %d  Skipped: %d  Total: %dm%ds\n" "$total_passed" "$total_failed" "$skipped_count" "$total_mins" "$total_secs"

    if [[ $total_failed -gt 0 ]]; then
        echo ""
        echo "  Failed items:"
        for fid in "${!_failed_ids[@]}"; do
            echo "    - $fid: ${_failed_ids[$fid]}"
        done
    fi

    if [[ $skipped_count -gt 0 ]]; then
        echo ""
        echo "  Not attempted (aborted early):"
        for sid in "${_skipped[@]}"; do
            echo "    - $sid"
        done
    fi
    echo ""
}

cmd_auto() {
    local scope="${1:-}"

    if [[ -z "$scope" ]]; then
        log_error "Usage: auto {done|p0|p1|p2} [--retries N] [--max-failures N] [--no-merge] [--pr] [--refine] [--quick] [--auto-review] [--dry-run]"
        echo "" >&2
        echo "Scopes:" >&2
        echo "  done  Drain entire backlog to completion" >&2
        echo "  p0    Complete all P0 (must) items" >&2
        echo "  p1    Complete all P0+P1 (must + should) items" >&2
        echo "  p2    Complete all P0–P2 (must + should + could) items" >&2
        return 1
    fi

    case "$scope" in
        done|p0|p1|p2) ;;
        *)
            log_error "Unknown scope: $scope (must be: done, p0, p1, p2)"
            return 1
            ;;
    esac
    shift

    cmd_run --_auto "$scope" "$@"
}

# Dry-run handler for cmd_run.
# Uses outer-scope locals: auto_mode, auto_scope, specific_id, quick_mode
_run_dry_run() {
    load_config
    cd "$PROJECT_ROOT"
    [[ "$quick_mode" == "true" ]] && MATURITY_ENABLED="false"

    if [[ "$auto_mode" == "true" ]]; then
        log_header "aishore auto $auto_scope - Dry Run"
        echo "Project: $PROJECT_ROOT"
        echo "Auto-groom: when ready < $AUTO_GROOM_THRESHOLD"
        echo "Circuit breaker: $AUTO_MAX_FAILURES consecutive failures"
    else
        log_header "aishore - Dry Run"
        echo "Project: $PROJECT_ROOT"
    fi
    echo ""

    local item_json
    if ! item_json=$(pick_item "$specific_id" ""); then
        if [[ -n "$specific_id" ]]; then
            log_error "Item not found: $specific_id — check backlog/backlog.json and backlog/bugs.json for valid item IDs"
        else
            log_warning "No ready items in backlog. Items need readyForSprint: true AND a commander's intent (>=20 chars). Run '.aishore/aishore groom' to prepare items."
        fi
        return 1
    fi

    local item_id item_title
    item_id=$(echo "$item_json" | jq -r '.id')
    item_title=$(echo "$item_json" | jq -r '.title // .description')

    log_subheader "Selected Item"
    echo "$item_json" | jq .
    echo ""

    # Advisory complexity warning in dry-run
    if ! check_readiness_gates "$item_id" 2>/dev/null; then
        if echo -e "$CHECK_GATES_WARNINGS" | grep -q "under-specified"; then
            log_warning "$item_id may be under-specified — consider adding more steps or scope"
            echo -e "$CHECK_GATES_WARNINGS" | grep -A 50 "under-specified"
