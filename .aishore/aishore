create_sprint() {
    local item_json="$1"
    local source="$2"
    local item_id
    item_id=$(echo "$item_json" | jq -r '.id')
    local title
    title=$(echo "$item_json" | jq -r '.title // .description')
    local now
    now=$(date -Iseconds)

    local tmp_sprint
    tmp_sprint="$(ensure_tmpdir)/sprint_create.json"
    jq -n \
        --arg sprintId "sprint-$(date +%s)" \
        --arg startedAt "$now" \
        --arg itemId "$item_id" \
        --arg title "$title" \
        --arg source "$source" \
        --argjson intent "$(echo "$item_json" | jq '.intent // null')" \
        --argjson desc "$(echo "$item_json" | jq '.description // null')" \
        --argjson steps "$(echo "$item_json" | jq '.steps // []')" \
        --argjson ac "$(echo "$item_json" | jq '.acceptanceCriteria // []')" \
        --argjson scope "$(echo "$item_json" | jq '.scope // []')" \
        '{
            sprintId: $sprintId,
            startedAt: $startedAt,
            status: "in_progress",
            item: {
                id: $itemId,
                title: $title,
                intent: $intent,
                description: $desc,
                sourceBacklog: $source,
                steps: $steps,
                acceptanceCriteria: $ac,
                scope: $scope,
                startedAt: $startedAt
            }
        }' > "$tmp_sprint"
    mv "$tmp_sprint" "$BACKLOG_DIR/sprint.json"

    ITEM_ID="$item_id"
    log_info "Sprint created: $item_id - $title"
}

mark_complete() {
    local item_id="$1"
    local source="$2"
    local attempts="${3:-1}"
    local now
    now=$(date -Iseconds)

    [[ -z "$source" ]] && { log_error "Cannot mark complete: source backlog is empty"; return 1; }

    # Update source backlog
    if ! update_item "$source" "$item_id" \
        '| . + {passes: true, status: "done", readyForSprint: false, completedAt: $ts}' \
        --arg ts "$now"; then
        log_error "Failed to update $source"
        return 1
    fi

    # Update sprint.json
    local tmp_sprint
    tmp_sprint="$(ensure_tmpdir)/sprint_update.json"
    if jq --arg ts "$now" --argjson attempts "$attempts" '.status = "completed" | .completedAt = $ts | .attempts = $attempts | .item.status = "passed" | .item.completedAt = $ts' \
        "$BACKLOG_DIR/sprint.json" > "$tmp_sprint" 2>/dev/null; then
        mv "$tmp_sprint" "$BACKLOG_DIR/sprint.json"
    else
        rm -f "$tmp_sprint"
        log_warning "Failed to update sprint.json status (item already marked complete in $source)"
    fi

    # Append enriched record to archive (non-fatal — primary state is already consistent)
    local sprint_id
    sprint_id=$(jq -r '.sprintId' "$BACKLOG_DIR/sprint.json" 2>/dev/null || echo "unknown")

    # Git diff stats
    local files_changed=0 lines_added=0 lines_removed=0
    local diffstat
    diffstat=$(git diff --shortstat HEAD~1 HEAD 2>/dev/null || true)
    if [[ -n "$diffstat" ]]; then
        files_changed=$(echo "$diffstat" | sed -n 's/.*\([0-9][0-9]*\) file.*/\1/p')
        lines_added=$(echo "$diffstat" | sed -n 's/.*\([0-9][0-9]*\) insertion.*/\1/p')
        lines_removed=$(echo "$diffstat" | sed -n 's/.*\([0-9][0-9]*\) deletion.*/\1/p')
    fi
    files_changed="${files_changed:-0}"
    lines_added="${lines_added:-0}"
    lines_removed="${lines_removed:-0}"

    # Duration from sprint start
    local duration=0
    local started_at
    started_at=$(jq -r '.startedAt // ""' "$BACKLOG_DIR/sprint.json" 2>/dev/null || true)
    if [[ -n "$started_at" ]]; then
        local start_epoch
        start_epoch=$(date -d "$started_at" +%s 2>/dev/null || date -j -f "%Y-%m-%dT%H:%M:%S" "${started_at%%+*}" +%s 2>/dev/null || echo 0)
        [[ "$start_epoch" -gt 0 ]] && duration=$(( $(date +%s) - start_epoch ))
    fi

    # Priority and category from source backlog item
    local item_priority="" item_category=""
    if [[ -n "$source" && -f "$BACKLOG_DIR/$source" ]]; then
        item_priority=$(jq -r --arg id "$item_id" '.items[] | select(.id == $id) | .priority // ""' "$BACKLOG_DIR/$source" 2>/dev/null || true)
        item_category=$(jq -r --arg id "$item_id" '.items[] | select(.id == $id) | .category // ""' "$BACKLOG_DIR/$source" 2>/dev/null || true)
    fi

    if ! jq -cn \
        --arg date "$(date +%Y-%m-%d)" \
        --arg sid "$sprint_id" \
        --arg iid "$item_id" \
        --argjson attempts "$attempts" \
        --argjson filesChanged "${files_changed}" \
        --argjson linesAdded "${lines_added}" \
        --argjson linesRemoved "${lines_removed}" \
        --argjson duration "$duration" \
        --arg priority "$item_priority" \
        --arg category "$item_category" \
        '{date: $date, sprintId: $sid, itemId: $iid, status: "complete", attempts: $attempts, filesChanged: $filesChanged, linesAdded: $linesAdded, linesRemoved: $linesRemoved, duration: $duration, priority: (if $priority == "" then null else $priority end), category: (if $category == "" then null else $category end)}' \
        >> "$ARCHIVE_DIR/sprints.jsonl" 2>/dev/null; then
        log_warning "Failed to append to archive — sprint data is still consistent"
    fi
}

reset_sprint() {
    cat > "$BACKLOG_DIR/sprint.json" <<'EOF'
{"sprintId": null, "status": "idle", "item": null}
EOF
}

# ============================================================================
# AGENT EXECUTION
# ============================================================================

# Core process management: launch claude agent and wait for result.json or timeout.
# Args: agent_label model allowed_tools output_format prompt
#   agent_label   - name for logging
#   model         - model to use
#   allowed_tools - comma-separated tool list
#   output_format - "text" or "stream-json" (use "text" for --print capture)
#   prompt        - full prompt string (including context @-files)
# Optional: set AGENT_OUTPUT_FILE before calling to capture --print output to a file.
# Optional: set GROOM_MONITOR=true to track backlog changes during the poll loop.

# Helper: portable file hash for change detection (not cryptographic)
_file_hash() {
    if command -v sha256sum &>/dev/null; then
        sha256sum "$1" | cut -d' ' -f1
    elif command -v shasum &>/dev/null; then
        shasum -a 256 "$1" | cut -d' ' -f1
    else
        cksum "$1" | cut -d' ' -f1
    fi
}

# Helper: detect and report backlog file changes during grooming
_check_groom_progress() {
    local label="$1"
    local changed=false

    if [[ -f "$BACKLOG_DIR/backlog.json" ]]; then
        local cur_hash
        cur_hash=$(_file_hash "$BACKLOG_DIR/backlog.json")
        if [[ "$cur_hash" != "$last_backlog_hash" ]]; then
            last_backlog_hash="$cur_hash"
            changed=true
            local ready total
            ready=$(count_ready_items "$BACKLOG_DIR/backlog.json")
            total=$(count_items "$BACKLOG_DIR/backlog.json")
            log_agent "$label" "backlog.json updated — $total items ($ready ready)"
        fi
    fi

    if [[ -f "$BACKLOG_DIR/bugs.json" ]]; then
        local cur_hash
        cur_hash=$(_file_hash "$BACKLOG_DIR/bugs.json")
        if [[ "$cur_hash" != "$last_bugs_hash" ]]; then
            last_bugs_hash="$cur_hash"
            changed=true
            local ready total
            ready=$(count_ready_items "$BACKLOG_DIR/bugs.json")
            total=$(count_items "$BACKLOG_DIR/bugs.json")
            log_agent "$label" "bugs.json updated — $total items ($ready ready)"
        fi
    fi

    if [[ "$changed" != "true" && $((elapsed % 30)) -eq 0 ]]; then
        log_agent "$label" "Working... (${elapsed}s elapsed)"
    fi
}

run_agent_process() {
    local agent_label="$1"
    local model="$2"
    local allowed_tools="$3"
    local output_format="$4"
    local prompt="$5"

    log_agent "$agent_label" "Starting (model: $model, timeout: ${AGENT_TIMEOUT}s)"
    local start_time
    start_time=$(date +%s)

    # Always capture agent output to a per-run log file for diagnostics
    local agent_log
    agent_log="$LOGS_DIR/${agent_label}-$(date +%Y%m%dT%H%M%S).log"
    LAST_AGENT_LOG="$agent_log"

    local has_setsid=false
    if command -v setsid &>/dev/null; then
        has_setsid=true
    fi

    local claude_args=(
        --model "$model"
        --permission-mode acceptEdits
        --allowedTools "$allowed_tools"
    )

    if [[ -n "${AGENT_OUTPUT_FILE:-}" ]]; then
        claude_args+=(--print)
        if [[ "$has_setsid" == true ]]; then
            setsid env -u CLAUDECODE -u CLAUDE_CODE_ENTRYPOINT \
                claude "${claude_args[@]}" \
                -p "$prompt" > "$AGENT_OUTPUT_FILE" 2>&1 &
        else
            env -u CLAUDECODE -u CLAUDE_CODE_ENTRYPOINT \
                claude "${claude_args[@]}" \
                -p "$prompt" > "$AGENT_OUTPUT_FILE" 2>&1 &
        fi
    else
        claude_args+=(--output-format "$output_format")
        if [[ "$has_setsid" == true ]]; then
            setsid env -u CLAUDECODE -u CLAUDE_CODE_ENTRYPOINT \
                claude "${claude_args[@]}" \
                -p "$prompt" > "$agent_log" 2>&1 &
        else
            env -u CLAUDECODE -u CLAUDE_CODE_ENTRYPOINT \
                claude "${claude_args[@]}" \
                -p "$prompt" > "$agent_log" 2>&1 &
        fi
    fi

    local agent_pid=$!
    local elapsed=0
    local got_result=false

    # Progress monitoring: track backlog file changes during grooming
    local monitor_backlogs="${GROOM_MONITOR:-false}"
    local last_backlog_hash="" last_bugs_hash=""
    if [[ "$monitor_backlogs" == "true" ]]; then
        [[ -f "$BACKLOG_DIR/backlog.json" ]] && last_backlog_hash=$(_file_hash "$BACKLOG_DIR/backlog.json")
        [[ -f "$BACKLOG_DIR/bugs.json" ]] && last_bugs_hash=$(_file_hash "$BACKLOG_DIR/bugs.json")
    fi

    while [[ $elapsed -lt $AGENT_TIMEOUT ]]; do
        if ! kill -0 "$agent_pid" 2>/dev/null; then
            break
        fi
        if [[ -f "$STATUS_DIR/result.json" ]]; then
            got_result=true
            sleep 2
            break
        fi
        sleep 5
        elapsed=$((elapsed + 5))

        # Check for backlog changes and report progress
        if [[ "$monitor_backlogs" == "true" && $((elapsed % 10)) -eq 0 ]]; then
            _check_groom_progress "$agent_label"
        elif [[ $((elapsed % 30)) -eq 0 ]]; then
            log_agent "$agent_label" "Waiting for agent... (${elapsed}s elapsed)"
        fi
    done

    # Kill the process if it's still running
    if kill -0 "$agent_pid" 2>/dev/null; then
        if [[ "$got_result" != "true" ]]; then
            log_warning "Agent timed out after ${AGENT_TIMEOUT}s, killing..."
        fi
        if [[ "$has_setsid" == true ]]; then
            kill -TERM -- -"$agent_pid" 2>/dev/null || kill -TERM "$agent_pid" 2>/dev/null
            sleep 2
            kill -KILL -- -"$agent_pid" 2>/dev/null || true
        else
            kill -TERM "$agent_pid" 2>/dev/null || true
            sleep 2
            kill -KILL "$agent_pid" 2>/dev/null || true
        fi
    fi

    wait "$agent_pid" 2>/dev/null || true

    # Copy AGENT_OUTPUT_FILE to agent log if used (so LAST_AGENT_LOG is always valid)
    if [[ -n "${AGENT_OUTPUT_FILE:-}" && -f "$AGENT_OUTPUT_FILE" ]]; then
        cp "$AGENT_OUTPUT_FILE" "$agent_log" 2>/dev/null || true
    fi

    local duration
    duration=$(($(date +%s) - start_time))
    log_agent "$agent_label" "Completed in ${duration}s"

    append_log "$LOGS_DIR/agent-runs.log" \
        "$(date -Iseconds)|$agent_label|${AGENT_MODE:-unknown}|${duration}s|$model"
}

build_agent_prompt() {
    local agent_name="$1"
    local mode="$2"
    local extra_prompt="${3:-}"

    local prompt_file="$AGENTS_DIR/${agent_name}.md"
    [[ ! -f "$prompt_file" ]] && { log_error "Agent not found: $agent_name"; return 1; }

    # Build orchestrator injections
    local validate_hint=""
    if [[ "$agent_name" == "developer" ]]; then
        validate_hint="
## Commander's Intent
The \`intent\` field in sprint.json is a non-negotiable directive — what must be true when done. When the spec is unclear or steps seem wrong, intent is the order you follow."

        if [[ -n "$FIX_CMD" ]]; then
            validate_hint="$validate_hint

## Auto-Fix
After you finish, the orchestrator will automatically run \`$FIX_CMD\` to fix lint/formatting issues. Do not worry about auto-fixable style issues — focus on correctness and AC."
        fi

        if [[ "$MATURITY_ENABLED" == "true" ]]; then
            validate_hint="$validate_hint

## Maturity Protocol (MANDATORY — complete all phases)
**Phase 1 — Implement:** Write the code. Follow spec, match patterns.${VALIDATE_CMD:+ Run \`$VALIDATE_CMD\` and fix failures.}
**Phase 2 — Critique:** STOP coding. Re-read every changed file. Verify intent is fulfilled and each AC is provably met. Hunt bugs, edge cases, dead code, missing error handling. Fix everything found.
**Phase 3 — Harden:** Run validation${VALIDATE_CMD:+ (\`$VALIDATE_CMD\`)} again. Fix regressions. Re-verify all AC. Only then commit and signal done.
Output phase markers: \`═══ PHASE 2: CRITIQUE ═══\` / \`═══ PHASE 3: HARDEN ═══\`"
        elif [[ -n "$VALIDATE_CMD" ]]; then
            validate_hint="$validate_hint

## Validation
Run \`$VALIDATE_CMD\` after implementing. Fix failures before writing result.json."
        fi
    elif [[ "$agent_name" == "validator" ]]; then
        validate_hint="
## Commander's Intent
The \`intent\` field in sprint.json is a non-negotiable directive. Verify the implementation fulfills it — AC can pass mechanically while intent is missed."
    elif [[ "$agent_name" == "tech-lead" || "$agent_name" == "product-owner" ]]; then
        validate_hint="
## Commander's Intent
Every item should have an \`intent\` field — a non-negotiable directive stating what must be true when done. Use \`--intent \"...\"\` when adding/editing items. Write it like an order, not a description.

## Grooming Limits
- **Maximum items per session:** $GROOM_MAX_ITEMS — stop adding new items after this cap. Focus on the highest-value items first.
- **Minimum priority threshold:** $GROOM_MIN_PRIORITY — only add items at \`$GROOM_MIN_PRIORITY\` priority or higher. Skip lower-priority items (log them in your summary but do not add them).
- When you reach the cap or run out of items above the threshold, stop and signal completion. Do not generate busywork."
        if [[ "$agent_name" == "product-owner" && "$mode" == "populate" ]]; then
            validate_hint="$validate_hint

## Populate Mode — Intent-Driven Development

You have been given a product requirements document. Your job is to populate the backlog with high-quality, sprint-ready items.

**This is the most important step in the entire pipeline.** Everything downstream depends on what you create here. The developer agent follows intent when the spec is ambiguous. The validator agent checks intent was fulfilled, not just that AC passed mechanically. Retries and refinement are guided by intent. A vague backlog means every sprint fails — the developer guesses wrong, the validator can't judge, retries spin in circles. A precise backlog means sprints succeed autonomously.

### Intent Is Everything

Commander's intent is the single most important field on every item. It is a non-negotiable directive — what must be true when this work is done. It answers: \"If the developer could only remember one thing, what should it be?\"

**Write intent like a commanding officer's order:**
- ✅ \"Users authenticate securely or are told exactly why they cannot. Never a blank screen or silent failure.\"
- ✅ \"Ops must know instantly if the service is alive or dead. No false positives. No silent degradation.\"
- ✅ \"Large uploads must complete or give clear progress. Users must never stare at a frozen screen.\"
- ❌ \"Add login\" — implementation, not outcome
- ❌ \"Improve auth\" — vague, no definition of success
- ❌ \"Make it faster\" — no specific bar to meet

Intent must be ≥20 characters. But length is not the goal — clarity is. A short, sharp directive beats a padded sentence. The developer reads this when the spec is confusing and needs to decide what matters.

### What Makes a Great Backlog Item

Each item needs ALL of these to succeed in an automated sprint:

1. **Title** — concise, specific, scannable (\"Add rate limiting to API endpoints\" not \"Backend stuff\")
2. **Intent** — the non-negotiable outcome directive (see above)
3. **Description** — enough context that a developer who has never seen the product doc can implement it. Include: what to build, why it matters, relevant constraints, and boundary conditions.
4. **Priority** — must (MVP/blocking), should (important), could (nice-to-have), future (later)
5. **Acceptance Criteria** — 3-5 specific, verifiable statements about user-visible outcomes. Each AC should be independently testable. Bad: \"it works\". Good: \"Unauthenticated requests to /api/* return 401 with a JSON error body\".

### Right-Sizing Items

Each item must be completable in a single sprint — one focused change. If you find yourself writing more than 5-6 AC or the description exceeds a paragraph, the item is too large. Split it.

**Split by user value, not by technical layer.** \"Add user registration\" → \"User can create account with email\" + \"User can verify email address\" + \"User can reset forgotten password\" — each delivers independent value.

### Process
1. Read the product requirements document thoroughly — understand the vision, not just the feature list
2. Check the existing backlog (\`.aishore/aishore backlog list\`) to avoid duplicates
3. Decompose the product vision into concrete, right-sized items
4. Add each item using the CLI (see example below)
5. Do NOT edit JSON files directly — use only CLI commands

### Example — Gold Standard Item
\`\`\`bash
.aishore/aishore backlog add \\\\
  --type feat \\\\
  --title \"OAuth2 login with Google\" \\\\
  --intent \"Users authenticate securely or are told exactly why they cannot. Never a blank screen or silent failure.\" \\\\
  --desc \"Implement OAuth2 authorization code flow with Google as the initial provider. Handle token refresh transparently, store tokens securely (httpOnly cookies, not localStorage), and provide clear error messages for network failures, denied permissions, and expired sessions. Must work with the existing session middleware.\" \\\\
  --priority must \\\\
  --ac \"User can click Sign In, complete Google OAuth flow, and land on their dashboard\" \\\\
  --ac \"Invalid or expired tokens trigger automatic refresh without user action\" \\\\
  --ac \"Auth errors display a specific, actionable message — not a generic error page\" \\\\
  --ac \"Signed-out users hitting protected routes are redirected to login with a return URL\" \\\\
  --ac \"Tokens are stored in httpOnly cookies, never exposed to client-side JavaScript\"
\`\`\`

Notice: intent states the outcome bar (\"securely or told why\"), description gives implementation context the developer needs, AC are independently verifiable user-visible behaviors.

### What Bad Looks Like (Never Do This)
| Field | Bad | Why It Fails |
|-------|-----|--------------|
| Title | \"Auth stuff\" | Developer doesn't know what to build |
| Intent | \"Add login\" | Too short, states implementation not outcome |
| Intent | \"We should probably have authentication\" | Hedge words, no bar to meet |
| Desc | (empty) | Developer has no context |
| AC | \"It works\" | Validator can't verify this |
| AC | \"Code is clean\" | Subjective, not testable |
| Scope | Entire backend | Must be split into focused items |"
        fi
    fi

    local prompt
    prompt="$(cat "$prompt_file")
${extra_prompt:+
$extra_prompt}${validate_hint:+
$validate_hint}

## Mode
$mode
$(build_completion_contract)"
    echo "$prompt"
}

run_agent() {
    local agent_name="$1"
    local mode="$2"
    local model="${3:-$MODEL_PRIMARY}"
    local context_args="${4:-}"
    local output_file="${5:-}"
    local extra_prompt="${6:-}"

    local prompt_file="$AGENTS_DIR/${agent_name}.md"
    [[ ! -f "$prompt_file" ]] && { log_error "Agent not found: $agent_name"; return 1; }

    rm -f "$STATUS_DIR/result.json"

    local context_files
    if [[ -n "$context_args" ]]; then
        context_files=$(AGENT_CONTEXT_ROLE="$agent_name" build_context $context_args)
    else
        context_files=$(AGENT_CONTEXT_ROLE="$agent_name" build_context "@$BACKLOG_DIR/sprint.json")
    fi

    # Derive permissions based on agent role and mode
    local agent_perms
    case "$agent_name" in
        developer)
            agent_perms="${CFG_PERMS_DEVELOPER:-$PERMS_DEVELOPER}" ;;
        validator)
            agent_perms="${CFG_PERMS_VALIDATOR:-$PERMS_VALIDATOR}" ;;
        architect)
            if [[ -n "$output_file" ]]; then
                agent_perms="${CFG_PERMS_REVIEWER:-$PERMS_REVIEWER_DOCS}"
            else
                agent_perms="${CFG_PERMS_REVIEWER:-$PERMS_REVIEWER}"
            fi ;;
        tech-lead|product-owner)
            # Groom agents need full permissions to update backlog files
            agent_perms="${CFG_PERMS_DEVELOPER:-$PERMS_DEVELOPER}" ;;
        *)
            agent_perms="${CFG_PERMS_DEVELOPER:-$PERMS_DEVELOPER}" ;;
    esac

    local prompt
    prompt=$(build_agent_prompt "$agent_name" "$mode" "$extra_prompt")

    if [[ -n "$output_file" ]]; then
        AGENT_OUTPUT_FILE="$output_file" AGENT_MODE="$mode" run_agent_process "$agent_name" "$model" \
            "$agent_perms" "" \
            "$context_files
$prompt"
    else
        AGENT_MODE="$mode" run_agent_process "$agent_name" "$model" \
            "$agent_perms" "text" \
            "$context_files
$prompt"
    fi
}

show_failure_log_tail() {
    if [[ -n "$LAST_AGENT_LOG" && -f "$LAST_AGENT_LOG" ]]; then
        local line_count
        line_count=$(wc -l < "$LAST_AGENT_LOG" 2>/dev/null || echo 0)
        if [[ "$line_count" -gt 0 ]]; then
            echo ""
            echo -e "${RED}── Last 20 lines of agent log ──${NC}"
            tail -n 20 "$LAST_AGENT_LOG" 2>/dev/null || true
            echo -e "${RED}── End of log tail ──${NC}"
        fi
        log_info "Full agent log: $LAST_AGENT_LOG"
    fi
}

check_result() {
    if [[ ! -f "$STATUS_DIR/result.json" ]]; then
        log_error "No result file - agent may have crashed"
        show_failure_log_tail
        return 1
    fi

    local status
    # Support both simple format {"status":"pass"} and detailed format {"overall":"PASS"}
    status=$(jq -r '.status // .overall // "unknown"' "$STATUS_DIR/result.json" 2>/dev/null)
    # Normalize to lowercase so PASS/pass both match
    status=$(echo "$status" | tr '[:upper:]' '[:lower:]')

    if [[ "$status" == "pass" ]]; then
        local summary
        summary=$(jq -r '.summary // .checks // "completed"' "$STATUS_DIR/result.json")
        log_success "$summary"
        return 0
    else
        local reason
        reason=$(jq -r '.reason // "unknown error"' "$STATUS_DIR/result.json")
        if [[ "$reason" == "unknown error" ]]; then
            # Include actual file contents to aid debugging
            local raw_content
            raw_content=$(cat "$STATUS_DIR/result.json" 2>/dev/null || echo "(unreadable)")
            log_error "Unexpected result format: $raw_content"
        else
            log_error "$reason"
        fi
        show_failure_log_tail
        return 1
    fi
}

SCOPE_VIOLATION_REPORT=""
check_scope_violations() {
    SCOPE_VIOLATION_REPORT=""
    local sprint_file="$BACKLOG_DIR/sprint.json"
    [[ ! -f "$sprint_file" ]] && return 0

    local scope_json
    scope_json=$(jq -r '.item.scope // empty' "$sprint_file" 2>/dev/null)
    [[ -z "$scope_json" || "$scope_json" == "null" || "$scope_json" == "[]" ]] && return 0

    local scope_count
    scope_count=$(echo "$scope_json" | jq 'length' 2>/dev/null || echo 0)
    [[ "$scope_count" -eq 0 ]] && return 0

    # Get changed files against base branch (developer may have multiple commits)
    local base_branch="$AISHORE_BASE_BRANCH"
    [[ -z "$base_branch" ]] && return 0

    local changed_files
    changed_files=$(git diff --name-only "$base_branch"...HEAD 2>/dev/null || true)
    [[ -z "$changed_files" ]] && return 0

    # Read scope globs into array
    local -a globs=()
    while IFS= read -r glob; do
        globs+=("$glob")
    done < <(echo "$scope_json" | jq -r '.[]' 2>/dev/null)

    local violations=""
    local violation_count=0
    while IFS= read -r file; do
        local in_scope=false
        for glob in "${globs[@]}"; do
            # Convert ** to * for bash pattern matching (simplistic but functional)
            local pattern="${glob//\*\*/*}"
            # shellcheck disable=SC2254,SC2053
            if [[ "$file" == $pattern ]]; then
                in_scope=true
                break
            fi
        done
        if [[ "$in_scope" != "true" ]]; then
            violations="${violations}  - $file\n"
            violation_count=$((violation_count + 1))
        fi
    done <<< "$changed_files"

    if [[ "$violation_count" -gt 0 ]]; then
        SCOPE_VIOLATION_REPORT="$violation_count file(s) outside declared scope:\n$violations"
        if [[ "$SCOPE_MODE" == "strict" ]]; then
            log_error "Scope violation (strict mode): $violation_count file(s) outside scope"
            echo -e "$violations"
            return 1
        else
            log_warning "Scope violation: $violation_count file(s) outside scope"
            echo -e "$violations"
            return 0
        fi
    fi
    return 0
}

AC_VERIFY_REPORT=""
run_ac_verification() {
    AC_VERIFY_REPORT=""
    local sprint_file="$BACKLOG_DIR/sprint.json"
    [[ ! -f "$sprint_file" ]] && return 0

    local ac_json
    ac_json=$(jq -r '.item.acceptanceCriteria // []' "$sprint_file" 2>/dev/null)
    [[ -z "$ac_json" || "$ac_json" == "null" || "$ac_json" == "[]" ]] && return 0

    # Filter to objects with .verify field
    local verifiable
    verifiable=$(echo "$ac_json" | jq '[.[] | select(type == "object" and .verify != null)]' 2>/dev/null)
    local verify_count
    verify_count=$(echo "$verifiable" | jq 'length' 2>/dev/null || echo 0)
    [[ "$verify_count" -eq 0 ]] && return 0

    log_info "Running $verify_count AC verification command(s)"
    local all_passed=true
    local report=""
    local idx=0

    while IFS= read -r entry; do
        local ac_text ac_cmd
        ac_text=$(echo "$entry" | jq -r '.text // "unnamed"')
        ac_cmd=$(echo "$entry" | jq -r '.verify')
        idx=$((idx + 1))

        local ac_ok=true
        local ac_tmpfile
        ac_tmpfile="$(ensure_tmpdir)/ac_verify_${idx}.txt"
        run_validated_command "$ac_cmd" "$ac_tmpfile" || ac_ok=false
        local ac_output
        ac_output=$(truncate_output "$ac_tmpfile")
        rm -f "$ac_tmpfile"

        if [[ "$ac_ok" == "true" ]]; then
            report="${report}  PASS: ${ac_text}"$'\n'
            log_success "AC: $ac_text"
        else
            report="${report}  FAIL: ${ac_text} (cmd: ${ac_cmd})"$'\n'"    Output: ${ac_output}"$'\n'
            log_error "AC: $ac_text"
            all_passed=false
        fi
    done < <(echo "$verifiable" | jq -c '.[]')

    AC_VERIFY_REPORT="$report"
    [[ "$all_passed" == "true" ]] && return 0 || return 1
}

