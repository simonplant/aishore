main() {
    mkdir -p "$STATUS_DIR" "$LOGS_DIR" "$ARCHIVE_DIR"

    local cmd="${1:-usage}"
    shift || true

    case "$cmd" in
        auto)    cmd_auto "$@" ;;
        run)     cmd_run "$@" ;;
        backlog) cmd_backlog "$@" ;;
        groom)   cmd_groom "$@" ;;
        review)  cmd_review "$@" ;;
        metrics) cmd_metrics "$@" ;;
        status)  cmd_status "$@" ;;
        update)  cmd_update "$@" ;;
        checksums) cmd_checksums ;;
        clean)   cmd_clean "$@" ;;
        diagnose) cmd_diagnose ;;

        init)    cmd_init "$@" ;;
        version|-v|--version) cmd_version ;;
        help|-h|--help) cmd_help ;;
        usage) cmd_usage ;;
        *)
            log_error "Unknown command: $cmd"
            cmd_usage >&2
            exit 1
            ;;
    esac
}

main "$@"
