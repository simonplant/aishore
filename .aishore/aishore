save_backlog_snapshot() {
    local snapshot_dir="$STATUS_DIR/backlog-snapshot"
    mkdir -p "$snapshot_dir"
    for f in "${BACKLOG_FILES[@]}"; do
        [[ -f "$BACKLOG_DIR/$f" ]] && cp "$BACKLOG_DIR/$f" "$snapshot_dir/$f" || true
    done
}

restore_backlog_snapshot() {
    local snapshot_dir="$STATUS_DIR/backlog-snapshot"
    for f in "${BACKLOG_FILES[@]}"; do
        [[ -f "$snapshot_dir/$f" ]] && cp "$snapshot_dir/$f" "$BACKLOG_DIR/$f" || true
    done
}

mark_item_failed() {
    local item_id="$1"
    local reason="$2"
    local source="$3"
    if [[ -z "$source" ]]; then
        log_warning "Cannot record failure for '$item_id': source backlog unknown"
        return 0
    fi
    local now
    now=$(date -Iseconds)
    if ! update_item "$source" "$item_id" \
        '| . + {lastFailReason: $reason, lastFailAt: $ts, failCount: ((.failCount // 0) + 1)}' \
        --arg reason "$reason" --arg ts "$now" 2>/dev/null; then
        log_warning "Failed to record sprint failure for $item_id"
    fi
    return 0
}

_cleanup_worktree() {
    # Remove worktree and restore paths to original project root
    if [[ -n "$AISHORE_WORKTREE_DIR" ]]; then
        cd "$PROJECT_ROOT" 2>/dev/null || true
        git worktree remove "$AISHORE_WORKTREE_DIR" --force 2>/dev/null || true
        [[ -d "$AISHORE_WORKTREE_DIR" ]] && rm -rf "$AISHORE_WORKTREE_DIR" 2>/dev/null || true
        AISHORE_WORKTREE_DIR=""

        # Restore paths to original project
        STATUS_DIR="$DATA_DIR/status"
        LOGS_DIR="$DATA_DIR/logs"
        BACKLOG_DIR="$PROJECT_ROOT/backlog"
        ARCHIVE_DIR="$BACKLOG_DIR/archive"
    fi
}

_store_failure_context() {
    local item_id="$1" reason="$2" detail="$3"
    local failure_file="$STATUS_DIR/last-failure.json"
    local result_content="{}"
    [[ -f "$STATUS_DIR/result.json" ]] && result_content=$(cat "$STATUS_DIR/result.json" 2>/dev/null || echo "{}")
    local agent_log_path="${LAST_AGENT_LOG:-}"
    local agent_stderr=""
    if [[ -n "$agent_log_path" && -f "$agent_log_path" ]]; then
        # Capture last 50 lines for stored context (more than the 20 shown inline)
        agent_stderr=$(tail -n 50 "$agent_log_path" 2>/dev/null || true)
    fi
    jq -n \
        --arg item_id "$item_id" \
        --arg reason "$reason" \
        --arg detail "$detail" \
        --arg timestamp "$(date -Iseconds)" \
        --arg agent_log "$agent_log_path" \
        --argjson result "$result_content" \
        --arg log_tail "$agent_stderr" \
        '{itemId: $item_id, reason: $reason, detail: $detail, timestamp: $timestamp, agentLog: $agent_log, result: $result, logTail: $log_tail}' \
        > "$failure_file" 2>/dev/null || true
}

handle_sprint_failure() {
    log_warning "Resetting working tree after sprint failure"

    if [[ -n "$AISHORE_WORKTREE_DIR" ]]; then
        # Worktree mode: remove worktree and delete the branch
        local fb="$AISHORE_FEATURE_BRANCH"
        AISHORE_FEATURE_BRANCH=""
        _cleanup_worktree
        [[ -n "$fb" ]] && git branch -D "$fb" 2>/dev/null || true
    elif [[ -n "$AISHORE_FEATURE_BRANCH" && -n "$AISHORE_BASE_BRANCH" ]]; then
        # Stash mode: switch back to base and delete the branch
        # (base branch still has backlog state from earlier successful sprints)
        local fb="$AISHORE_FEATURE_BRANCH"
        AISHORE_FEATURE_BRANCH=""
        git checkout "$AISHORE_BASE_BRANCH" 2>/dev/null || true
        git branch -D "$fb" 2>/dev/null || true
    else
        # Fallback for non-branching context
        local snapshot_dir="$STATUS_DIR/backlog-snapshot"
        local has_snapshot=false
        [[ -d "$snapshot_dir" ]] && has_snapshot=true

        git reset HEAD -- . 2>/dev/null || true
        git checkout -- . 2>/dev/null || true
        git clean -fd -e '.aishore' 2>/dev/null || true

        if [[ "$has_snapshot" == true ]]; then
            restore_backlog_snapshot
        fi
    fi
    reset_sprint
}

