cmd_backlog() {
    require_tool jq
    local subcmd="${1:-list}"
    shift || true
    case "$subcmd" in
        list|ls)    cmd_backlog_list "$@" ;;
        add|new)    cmd_backlog_add "$@" ;;
        show)       cmd_backlog_show "$@" ;;
        edit)       cmd_backlog_edit "$@" ;;
        rm|remove)  cmd_backlog_rm "$@" ;;
        check)      cmd_backlog_check "$@" ;;
        history)    cmd_backlog_history "$@" ;;
        sync)       cmd_backlog_sync "$@" ;;
        populate)   cmd_backlog_populate "$@" ;;
        *)
            log_error "Unknown backlog command: $subcmd"
            echo "Usage: backlog {list|add|show|edit|check|rm|history|sync|populate}" >&2
            return 1
            ;;
    esac
}

cmd_backlog_check() {
    local id="${1:-}"
    [[ -z "$id" ]] && { log_error "Usage: backlog check <ID>"; return 1; }
    [[ $# -gt 1 ]] && { log_error "Unexpected argument: ${2}"; return 1; }

    # Verify item exists
    find_item "$id" >/dev/null || return 1

    if check_readiness_gates "$id"; then
        log_success "$id passes all readiness gates"
    else
        log_warning "$id has readiness warnings:"
        echo -e "$CHECK_GATES_WARNINGS"
        return 1
    fi
}

cmd_backlog_populate() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            *) log_error "Unknown option: $1"; return 1 ;;
        esac
    done

    if [[ ! -f "$BACKLOG_DIR/backlog.json" ]]; then
        log_error "aishore not initialized — run '.aishore/aishore init' first"
        return 1
    fi

    acquire_lock
    load_config
    cd "$PROJECT_ROOT"

    log_header "Product Owner: Populate Backlog"

    # Find product requirements doc
    local prd_file=""
    for candidate in \
        "$PROJECT_ROOT/PRODUCT.md" "$PROJECT_ROOT/product.md" \
        "$PROJECT_ROOT/PRD.md" "$PROJECT_ROOT/prd.md" \
        "$PROJECT_ROOT/docs/PRODUCT.md" "$PROJECT_ROOT/docs/product.md" \
        "$PROJECT_ROOT/docs/PRD.md" "$PROJECT_ROOT/docs/prd.md" \
        "$PROJECT_ROOT/docs/WEBSITE_BRIEF.md" \
        "$PROJECT_ROOT/README.md"; do
        if [[ -f "$candidate" ]]; then
            prd_file="$candidate"
            break
        fi
    done

    if [[ -z "$prd_file" ]]; then
        log_error "No product requirements doc found (PRODUCT.md, PRD.md, README.md, etc.)"
        echo "  Create a PRODUCT.md or docs/PRODUCT.md describing what you're building."
        return 1
    fi

    # Guard against empty scaffold templates
    local content_lines
    content_lines=$(grep -cvE '^\s*$|^\s*#|^\s*<!--|^\s*-->|^\s*- \[ \]' "$prd_file" 2>/dev/null || echo 0)
    if [[ "$content_lines" -lt 3 ]]; then
        log_error "Product doc appears to be an empty template: $prd_file"
        echo "  Fill in your product vision, target users, and core features before populating."
        echo "  The backlog quality depends entirely on the quality of this document."
        return 1
    fi

    log_info "Using requirements from: $prd_file"

    local context_args="@$prd_file @$BACKLOG_DIR/backlog.json @$BACKLOG_DIR/bugs.json"
    # Include definitions doc for quality examples if available
    [[ -f "$BACKLOG_DIR/DEFINITIONS.md" ]] && context_args="$context_args @$BACKLOG_DIR/DEFINITIONS.md"

    # Snapshot backlog state for progress tracking
    local snap_before
    snap_before=$(snapshot_backlogs)

    # Snapshot existing items to protect from agent overwrites
    local populate_snap_dir
    populate_snap_dir=$(mktemp -d)
    for f in "${BACKLOG_FILES[@]}"; do
        [[ -f "$BACKLOG_DIR/$f" ]] && cp "$BACKLOG_DIR/$f" "$populate_snap_dir/$f"
    done

    log_info "Running product-owner agent to populate backlog..."
    echo ""

    GROOM_MONITOR=true run_agent "product-owner" "populate" "$MODEL_FAST" "$context_args"

    # Protect existing items from agent rewrites, then enforce limits
    protect_items_from_groom "$populate_snap_dir"
    enforce_groom_limits "$populate_snap_dir"
    rm -rf "$populate_snap_dir"

    # --- Post-populate diff ---
    print_groom_diff "$snap_before"

    if ! check_result; then
        exit 1
    fi
}

cmd_backlog_list() {
    local filter_status="" filter_type="" filter_ready=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --status)  validate_arg "$1" "${2:-}" || return 1; filter_status="$2"; shift 2 ;;
            --type)    validate_arg "$1" "${2:-}" || return 1; filter_type="$2"; shift 2 ;;
            --ready)   filter_ready=true; shift ;;
            *) log_error "Unknown option: $1"; return 1 ;;
        esac
    done

    # Determine which files to scan
    local files=()
    case "$filter_type" in
        feat|feature) files=("backlog.json") ;;
        bug)          files=("bugs.json") ;;
        "")           files=("${BACKLOG_FILES[@]}") ;;
        *) log_error "Invalid type: $filter_type (must be: feat, bug)"; return 1 ;;
    esac

    # Build jq filter
    local jq_filter='.items[]'
    if [[ -n "$filter_status" ]]; then
        validate_status "$filter_status" || return 1
        jq_filter="$jq_filter | select((.status // \"todo\") == \"$filter_status\")"
    fi
    if [[ "$filter_ready" == "true" ]]; then
        jq_filter="$jq_filter | select(.readyForSprint == true)"
    fi

    # Collect done IDs for dependency checking
    local done_ids
    done_ids=$(collect_done_ids)

    # Header
    printf "%-10s %-8s %-13s %-6s %-20s %s\n" "ID" "PRI" "STATUS" "READY" "BLOCKED" "TITLE"
    printf "%-10s %-8s %-13s %-6s %-20s %s\n" "──────────" "────────" "─────────────" "──────" "────────────────────" "─────────────────────────────"

    local count=0
    for f in "${files[@]}"; do
        [[ -f "$BACKLOG_DIR/$f" ]] || continue
        local items
        # shellcheck disable=SC1010
        items=$(jq -r --argjson done "$done_ids" "[$jq_filter] | sort_by(if .priority == \"must\" then 0 elif .priority == \"should\" then 1 elif .priority == \"could\" then 2 else 3 end) | .[] | [.id, .priority // \"-\", .status // \"todo\", (if .readyForSprint then \"yes\" else \"no\" end), ((.dependsOn // []) | map(select(. as \$d | \$done | index(\$d) | not)) | if length == 0 then \"-\" else join(\",\") end), .title] | @tsv" "$BACKLOG_DIR/$f" 2>/dev/null) || continue
        if [[ -n "$items" ]]; then
            while IFS=$'\t' read -r id pri status ready blocked title; do
                local blocked_display=""
                if [[ "$blocked" != "-" ]]; then
                    blocked_display="[blocked: $blocked]"
                fi
                printf "%-10s %-8s %-13s %-6s %-20s %s\n" "$id" "$pri" "$status" "$ready" "$blocked_display" "$title"
                ((count++)) || true
            done <<< "$items"
        fi
    done

    echo ""
    echo "$count item(s)"
}

cmd_backlog_add() {
    local item_type="feat" title="" intent="" desc="" priority="should" category="" ready=false
    local depends_on=""
    local -a ac_entries=()
    local pending_ac=""
    local -a step_entries=()
    local -a scope_entries=()

    local interactive=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --interactive) interactive=true; shift ;;
            --type)
                validate_arg "$1" "${2:-}" || return 1
                item_type="$2"; shift 2 ;;
            --title)
                validate_arg "$1" "${2:-}" || return 1
                title="$2"; shift 2 ;;
            --intent)
                validate_arg "$1" "${2:-}" || return 1
                intent="$2"; shift 2 ;;
            --desc)
                validate_arg "$1" "${2:-}" || return 1
                desc="$2"; shift 2 ;;
            --priority)
                validate_arg "$1" "${2:-}" || return 1
                priority="$2"; shift 2 ;;
            --category)
                validate_arg "$1" "${2:-}" || return 1
                category="$2"; shift 2 ;;
            --ready)     ready=true; shift ;;
            --depends-on)
                validate_arg "$1" "${2:-}" || return 1
                depends_on="$2"; shift 2 ;;
            --ac)
                validate_arg "$1" "${2:-}" || return 1
                # Flush any pending AC entry as plain string
                if [[ -n "$pending_ac" ]]; then
                    ac_entries+=("$(printf '%s' "$pending_ac" | jq -Rs .)")
                fi
                pending_ac="$2"
                shift 2 ;;
            --ac-verify)
                validate_arg "$1" "${2:-}" || return 1
                if [[ -z "$pending_ac" ]]; then
                    log_error "--ac-verify must follow --ac"
                    return 1
                fi
                ac_entries+=("{\"text\":$(printf '%s' "$pending_ac" | jq -Rs .),\"verify\":$(printf '%s' "$2" | jq -Rs .)}")
                pending_ac=""
                shift 2 ;;
            --step)
                validate_arg "$1" "${2:-}" || return 1
                step_entries+=("$2")
                shift 2 ;;
            --scope)
                validate_arg "$1" "${2:-}" || return 1
                scope_entries+=("$2")
                shift 2 ;;
            *) log_error "Unknown option: $1"; return 1 ;;
        esac
    done

    # Flush last pending AC
    if [[ -n "$pending_ac" ]]; then
        ac_entries+=("$(printf '%s' "$pending_ac" | jq -Rs .)")
    fi

    # Interactive mode: triggered when no title provided, or --interactive flag
    if [[ -z "$title" ]] || [[ "$interactive" == "true" ]]; then
        if [[ ! -t 0 ]]; then
            log_error "No --title provided and stdin is not interactive"
            return 1
        fi
        echo "Add new backlog item (interactive mode)"
        echo ""

        # Type
        echo "  Type: feat (feature) or bug"
        echo "  Example: feat"
        read -r -p "  Type [${item_type}]: " input
        [[ -n "$input" ]] && item_type="$input"
        echo ""

        # Title
        echo "  Title: a short, descriptive name for the item"
        echo "  Example: add CSV export to reports page"
        if [[ -n "$title" ]]; then
            read -r -p "  Title [${title}]: " input
            [[ -n "$input" ]] && title="$input"
        else
            read -r -p "  Title: " title
            [[ -z "$title" ]] && { log_error "Title is required"; return 1; }
        fi
        echo ""

        # Intent
        echo "  Intent: a directive stating what must be true when done (>=20 chars)"
        echo "  Example: Users must be able to export any report as CSV from the UI"
        if [[ -n "$intent" ]]; then
            read -r -p "  Intent [${intent}]: " input
            [[ -n "$input" ]] && intent="$input"
        else
            read -r -p "  Intent: " intent
        fi
        echo ""

        # Priority
        echo "  Priority: must (P0), should (P1), could (P2), future (P3)"
        echo "  Example: should"
        read -r -p "  Priority [${priority}]: " input
        [[ -n "$input" ]] && priority="$input"
        echo ""

        # Steps
        echo "  Steps: implementation steps (press Enter on empty line to finish)"
        echo "  Example: Add export button to report toolbar"
        local step_n=1
        while true; do
            local step_input=""
            read -r -p "  Step ${step_n} (empty to finish): " step_input
            [[ -z "$step_input" ]] && break
            step_entries+=("$step_input")
            step_n=$((step_n + 1))
        done
        echo ""

        # Acceptance Criteria
        echo "  Acceptance criteria: testable conditions that prove the item is done"
        echo "  Example: Clicking Export CSV downloads a valid CSV file"
        local ac_n=1
        while true; do
            local ac_input=""
            read -r -p "  AC ${ac_n} (empty to finish): " ac_input
            [[ -z "$ac_input" ]] && break
            ac_entries+=("$(printf '%s' "$ac_input" | jq -Rs .)")
            ac_n=$((ac_n + 1))
        done
        echo ""

        # Summary
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo "  Type:     ${item_type}"
        echo "  Title:    ${title}"
        echo "  Intent:   ${intent:-<none>}"
        echo "  Priority: ${priority}"
        if [[ ${#step_entries[@]} -gt 0 ]]; then
            echo "  Steps:"
            for s in "${step_entries[@]}"; do
                echo "    - ${s}"
            done
        else
            echo "  Steps:    <none>"
        fi
        if [[ ${#ac_entries[@]} -gt 0 ]]; then
            echo "  AC:"
            for a in "${ac_entries[@]}"; do
                # ac_entries are jq-encoded strings; decode for display
                echo "    - $(printf '%s' "$a" | jq -r .)"
            done
        else
            echo "  AC:       <none>"
        fi
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo ""

        local confirm=""
        read -r -p "  Create this item? (Y/n) " confirm
        if [[ "$confirm" == "n" || "$confirm" == "N" ]]; then
            echo "Cancelled."
            return 0
        fi
    fi

    # Validate
    case "$item_type" in
        feat|feature) item_type="feat" ;;
        bug) ;;
        *) log_error "Invalid type: $item_type (must be: feat, bug)"; return 1 ;;
    esac
    validate_priority "$priority" || return 1

    # Determine prefix and target file
    local prefix target_file
    if [[ "$item_type" == "feat" ]]; then
        prefix="FEAT"
        target_file="backlog.json"
    else
        prefix="BUG"
        target_file="bugs.json"
    fi

    # Generate ID
    local new_id
    new_id=$(next_id "$prefix")

    # Build AC array
    local ac_json="[]"
    if [[ ${#ac_entries[@]} -gt 0 ]]; then
        ac_json="["
        local first=true
        for entry in "${ac_entries[@]}"; do
            [[ "$first" == "true" ]] && first=false || ac_json="$ac_json,"
            ac_json="$ac_json$entry"
        done
        ac_json="$ac_json]"
    fi

    # Build steps array
    local steps_json="[]"
    if [[ ${#step_entries[@]} -gt 0 ]]; then
        steps_json=$(printf '%s\n' "${step_entries[@]}" | jq -R . | jq -s .)
    fi

    # Build scope array
    local scope_json="[]"
    if [[ ${#scope_entries[@]} -gt 0 ]]; then
        scope_json=$(printf '%s\n' "${scope_entries[@]}" | jq -R . | jq -s .)
    fi

    # Build dependsOn array
    local depends_json="[]"
    if [[ -n "$depends_on" ]]; then
        depends_json=$(printf '%s' "$depends_on" | tr ',' '\n' | jq -R . | jq -s .)
    fi

    # Create item and append
    if ! add_item "$target_file" \
        --arg id "$new_id" \
        --arg title "$title" \
        --arg intent "$intent" \
        --arg desc "$desc" \
        --arg priority "$priority" \
        --arg category "$category" \
        --argjson ready "$ready" \
        --argjson ac_arr "$ac_json" \
        --argjson deps "$depends_json" \
        --argjson steps_arr "$steps_json" \
        --argjson scope_arr "$scope_json" \
        '.items += [{
            id: $id,
            title: $title,
            intent: (if $intent == "" then null else $intent end),
            description: $desc,
            priority: $priority,
            category: (if $category == "" then null else $category end),
            steps: $steps_arr,
            acceptanceCriteria: $ac_arr,
            scope: $scope_arr,
            dependsOn: (if ($deps | length) > 0 then $deps else [] end),
            status: "todo",
            passes: false,
            readyForSprint: $ready
        }]'; then
        log_error "Failed to add item"
        return 1
    fi

    log_success "Created $new_id: $title"
}

cmd_backlog_show() {
    local id="${1:-}"
    [[ -z "$id" ]] && { log_error "Usage: backlog show <ID>"; return 1; }
    [[ $# -gt 1 ]] && { log_error "Unexpected argument: ${2}"; return 1; }

    local item
    item=$(find_item "$id") || return 1

    echo ""
    echo "$item" | jq -r '
        "ID:          \(.id)",
        "Title:       \(.title)",
        "Status:      \(.status // "todo")",
        "Priority:    \(.priority // "-")",
        "Category:    \(.category // "-")",
        "Ready:       \(if .readyForSprint then "yes" else "no" end)",
        "Passes:      \(if .passes then "yes" else "no" end)",
        "",
        if .intent then "Intent:      \(.intent)\n" else empty end,
        "Description: \(.description // "-")",
        "",
        if (.steps // [] | length) > 0 then "Steps:" else empty end,
        (.steps // [] | to_entries[] | "  \(.key + 1). \(.value)"),
        if (.steps // [] | length) > 0 then "" else empty end,
        if (.acceptanceCriteria // [] | length) > 0 then "Acceptance Criteria:" else empty end,
        (.acceptanceCriteria // [] | .[] | if type == "object" then "  - \(.text)" + (if .verify then " (verify: \(.verify))" else "" end) else "  - \(.)" end),
        if (.dependsOn // [] | length) > 0 then "\nDependencies: \(.dependsOn | join(", "))" else empty end,
        if .groomedAt then "\nGroomed:      \(.groomedAt)" else empty end,
        if .groomingNotes then "Notes:        \(.groomingNotes)" else empty end,
        if .completedAt then "Completed:    \(.completedAt)" else empty end
    '
}

cmd_backlog_edit() {
    local id="${1:-}"
    [[ -z "$id" ]] && { log_error "Usage: backlog edit <ID> [--title ...] [--intent ...] [--priority ...] [--status ...] [--desc ...] [--category ...] [--depends-on ...] [--clear-depends-on] [--ready] [--no-ready] [--step ...] [--clear-steps] [--scope ...] [--clear-scope] [--ac ...] [--ac-verify ...] [--clear-ac] [--groomed-at ...] [--groomed-notes ...]"; return 1; }
    shift

    # Verify item exists
    find_item "$id" >/dev/null || return 1

    local file
    file=$(resolve_backlog_file "$id") || return 1

    # Parse update flags
    local updates=() update_desc=""
    local jq_updates=""
    local setting_ready=false
    local -a ac_entries=()
    local pending_ac=""
    local -a scope_vals=()
    local -a step_vals=()
    local -a deps_vals=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --title)
                validate_arg "$1" "${2:-}" || return 1
                jq_updates="$jq_updates | .title = \$title"
                updates+=("--arg" "title" "$2")
                update_desc="$update_desc title"
                shift 2 ;;
            --intent)
                validate_arg "$1" "${2:-}" || return 1
                jq_updates="$jq_updates | .intent = \$intent"
                updates+=("--arg" "intent" "$2")
                update_desc="$update_desc intent"
                shift 2 ;;
            --desc)
                validate_arg "$1" "${2:-}" || return 1
                jq_updates="$jq_updates | .description = \$desc"
                updates+=("--arg" "desc" "$2")
                update_desc="$update_desc description"
                shift 2 ;;
            --priority)
                validate_arg "$1" "${2:-}" || return 1
                validate_priority "$2" || return 1
                jq_updates="$jq_updates | .priority = \$priority"
                updates+=("--arg" "priority" "$2")
                update_desc="$update_desc priority"
                shift 2 ;;
            --status)
                validate_arg "$1" "${2:-}" || return 1
                validate_status "$2" || return 1
                jq_updates="$jq_updates | .status = \$status"
                updates+=("--arg" "status" "$2")
                update_desc="$update_desc status"
                shift 2 ;;
            --category)
                validate_arg "$1" "${2:-}" || return 1
                jq_updates="$jq_updates | .category = \$category"
                updates+=("--arg" "category" "$2")
                update_desc="$update_desc category"
                shift 2 ;;
            --ready)
                jq_updates="$jq_updates | .readyForSprint = true"
                update_desc="$update_desc ready"
                setting_ready=true
                shift ;;
            --no-ready)
                jq_updates="$jq_updates | .readyForSprint = false"
                update_desc="$update_desc ready"
                shift ;;
            --scope)
                validate_arg "$1" "${2:-}" || return 1
                scope_vals+=("$2")
                update_desc="$update_desc scope"
                shift 2 ;;
            --clear-scope)
                jq_updates="$jq_updates | .scope = []"
                update_desc="$update_desc scope"
                shift ;;
            --step)
                validate_arg "$1" "${2:-}" || return 1
                step_vals+=("$2")
                update_desc="$update_desc steps"
                shift 2 ;;
            --clear-steps)
                jq_updates="$jq_updates | .steps = []"
                update_desc="$update_desc steps"
                shift ;;
            --depends-on)
                validate_arg "$1" "${2:-}" || return 1
                # Split comma-separated values and accumulate
                while IFS= read -r dep; do
                    [[ -n "$dep" ]] && deps_vals+=("$dep")
                done < <(printf '%s\n' "$2" | tr ',' '\n')
                update_desc="$update_desc dependsOn"
                shift 2 ;;
            --clear-depends-on)
                jq_updates="$jq_updates | .dependsOn = []"
                update_desc="$update_desc dependsOn"
                shift ;;
            --ac)
                validate_arg "$1" "${2:-}" || return 1
                # Flush any pending AC entry
                if [[ -n "$pending_ac" ]]; then
                    ac_entries+=("$(printf '%s' "$pending_ac" | jq -Rs .)")
                fi
                pending_ac="$2"
                update_desc="$update_desc ac"
                shift 2 ;;
            --ac-verify)
                validate_arg "$1" "${2:-}" || return 1
                if [[ -z "$pending_ac" ]]; then
                    log_error "--ac-verify must follow --ac"
                    return 1
                fi
                # Convert pending AC to object with verify
                ac_entries+=("{\"text\":$(printf '%s' "$pending_ac" | jq -Rs .),\"verify\":$(printf '%s' "$2" | jq -Rs .)}")
                pending_ac=""
                shift 2 ;;
            --clear-ac)
                jq_updates="$jq_updates | .acceptanceCriteria = []"
                update_desc="$update_desc ac"
                shift ;;
            --groomed-notes)
                validate_arg "$1" "${2:-}" || return 1
                jq_updates="$jq_updates | .groomingNotes = \$gnotes"
                updates+=("--arg" "gnotes" "$2")
                update_desc="$update_desc groomingNotes"
                shift 2 ;;
            --groomed-at)
                local gdate
                if [[ -n "${2:-}" && "${2:-}" != --* ]]; then
                    gdate="$2"
                    if ! [[ "$gdate" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]]; then
                        log_error "Invalid date format: $gdate (expected YYYY-MM-DD)"
                        return 1
                    fi
                    shift 2
                else
                    gdate=$(date +%Y-%m-%d)
                    shift
                fi
                jq_updates="$jq_updates | .groomedAt = \$gdate"
                updates+=("--arg" "gdate" "$gdate")
                update_desc="$update_desc groomedAt"
                ;;
            *) log_error "Unknown option: $1"; return 1 ;;
        esac
    done

    # Flush last pending AC entry (plain string)
    if [[ -n "$pending_ac" ]]; then
        ac_entries+=("$(printf '%s' "$pending_ac" | jq -Rs .)")
    fi

    # Build scope jq update if any --scope flags were used
    if [[ ${#scope_vals[@]} -gt 0 ]]; then
        local scope_json
        scope_json=$(printf '%s\n' "${scope_vals[@]}" | jq -R . | jq -s .)
        jq_updates="$jq_updates | .scope = ((.scope // []) + \$newscope)"
        updates+=("--argjson" "newscope" "$scope_json")
    fi

    # Build steps jq update if any --step flags were used
    if [[ ${#step_vals[@]} -gt 0 ]]; then
        local steps_json
        steps_json=$(printf '%s\n' "${step_vals[@]}" | jq -R . | jq -s .)
        jq_updates="$jq_updates | .steps = ((.steps // []) + \$newsteps)"
        updates+=("--argjson" "newsteps" "$steps_json")
    fi

    # Build dependsOn jq update if any --depends-on flags were used
    if [[ ${#deps_vals[@]} -gt 0 ]]; then
        local deps_json
        deps_json=$(printf '%s\n' "${deps_vals[@]}" | jq -R . | jq -s .)
        jq_updates="$jq_updates | .dependsOn = ((.dependsOn // []) + \$newdeps) | .dependsOn |= unique"
        updates+=("--argjson" "newdeps" "$deps_json")
    fi

    # Build AC jq update if any --ac flags were used
    if [[ ${#ac_entries[@]} -gt 0 ]]; then
        local ac_json="["
        local first=true
        for entry in "${ac_entries[@]}"; do
            [[ "$first" == "true" ]] && first=false || ac_json="$ac_json,"
            ac_json="$ac_json$entry"
        done
        ac_json="$ac_json]"
        jq_updates="$jq_updates | .acceptanceCriteria = ((.acceptanceCriteria // []) + \$newac)"
        updates+=("--argjson" "newac" "$ac_json")
    fi

    if [[ -z "$jq_updates" ]]; then
        log_error "No updates specified. Use --title, --intent, --priority, --status, --desc, --category, --depends-on, --clear-depends-on, --ready, --no-ready, --step, --clear-steps, --scope, --clear-scope, --ac, --ac-verify, --clear-ac, --groomed-at, --groomed-notes"
        return 1
    fi

    if ! update_item "$file" "$id" "$jq_updates" "${updates[@]}"; then
        log_error "Failed to update item"
        return 1
    fi

    log_success "Updated $id:$update_desc"

    # Run readiness gates when setting --ready (warn but don't block)
    if [[ "$setting_ready" == "true" ]]; then
        if ! check_readiness_gates "$id"; then
            log_warning "Readiness warnings for $id:"
            echo -e "$CHECK_GATES_WARNINGS"
        fi
    fi
}

validate_arg() {
    local flag="$1" val="$2"
    if [[ -z "$val" || "$val" == --* ]]; then
        log_error "$flag requires a value"
        return 1
    fi
}

cmd_backlog_history() {
    local since="" failed_only=false limit=0

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --since)
                [[ -z "${2:-}" ]] && { log_error "Usage: backlog history [--since YYYY-MM-DD] [--failed] [--limit N]"; return 1; }
                since="$2"
                if ! [[ "$since" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]]; then
                    log_error "Invalid date format: $since (expected YYYY-MM-DD)"
                    return 1
                fi
                shift 2
                ;;
            --limit)
                validate_arg "$1" "${2:-}" || return 1
                limit="$2"
                if ! [[ "$limit" =~ ^[1-9][0-9]*$ ]]; then
                    log_error "Invalid limit: $limit (must be a positive integer)"
                    return 1
                fi
                shift 2
                ;;
            --failed)
                failed_only=true
                shift
                ;;
            *)
                log_error "Unknown option: $1"
                echo "Usage: backlog history [--since YYYY-MM-DD] [--failed] [--limit N]" >&2
                return 1
                ;;
        esac
    done

    local sprints_file="$ARCHIVE_DIR/sprints.jsonl"
    if [[ ! -f "$sprints_file" || ! -s "$sprints_file" ]]; then
        echo "No sprint history found"
        return 0
    fi

    local jq_filter='.'
    if [[ -n "$since" ]]; then
        jq_filter="select(.date >= \"$since\")"
    fi
    if [[ "$failed_only" == "true" ]]; then
        jq_filter="$jq_filter | select(.status != \"complete\")"
    fi

    local results
    results=$(jq -c "$jq_filter" "$sprints_file" 2>/dev/null) || true

    if [[ -z "$results" ]]; then
        echo "No matching sprint history entries"
        return 0
    fi

    # Build title lookup map from active backlogs
    declare -A title_map
    local bf
    for bf in "${BACKLOG_FILES[@]}"; do
        [[ -f "$BACKLOG_DIR/$bf" ]] || continue
        while IFS=$'\t' read -r _id _title; do
            title_map["$_id"]="$_title"
        done < <(jq -r '.items[] | [.id, .title] | @tsv' "$BACKLOG_DIR/$bf" 2>/dev/null || true)
    done

    # Print table header
    printf "%-12s %-12s %-10s %-10s %s\n" "ID" "DATE" "STATUS" "DURATION" "TITLE"
    printf "%-12s %-12s %-10s %-10s %s\n" "──────────" "──────────" "────────" "────────" "─────────────────────"

    local formatted
    formatted=$(echo "$results" | jq -r '[.itemId // "-", .date // "-", .status // "-", (if (.duration // 0) > 0 then (if .duration >= 60 then "\(.duration / 60 | floor)m \(.duration % 60)s" else "\(.duration)s" end) else "-" end)] | @tsv' | \
        while IFS=$'\t' read -r id date status duration; do
            local title="${title_map[$id]:-"-"}"
            printf "%-12s %-12s %-10s %-10s %s\n" "$id" "$date" "$status" "$duration" "$title"
        done)

    if [[ "$limit" -gt 0 ]]; then
        echo "$formatted" | tail -n "$limit"
    else
        echo "$formatted"
    fi
}

cmd_backlog_sync() {
    local dry_run=false auto_mark=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dry-run) dry_run=true; shift ;;
            --auto)    auto_mark=true; shift ;;
            *)
                log_error "Unknown option: $1"
                echo "Usage: backlog sync [--dry-run] [--auto]" >&2
                return 1
                ;;
        esac
    done

    # Detect default branch for comparison
    local default_branch=""
    default_branch=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@') || true
    if [[ -z "$default_branch" ]]; then
        for candidate in main master; do
            if git rev-parse --verify "$candidate" >/dev/null 2>&1; then
                default_branch="$candidate"
                break
            fi
        done
    fi
    if [[ -z "$default_branch" ]]; then
        log_error "Cannot detect default branch (main/master). Cannot compare git history."
        return 1
    fi

    # Get files changed on current branch relative to default branch
    local current_branch changed_files=""
    current_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null) || true
    if [[ "$current_branch" != "$default_branch" ]]; then
        changed_files=$(git log --name-only --pretty=format: "$default_branch"..HEAD 2>/dev/null | sort -u | grep -v '^$') || true
    fi
    # Fallback: if on default branch or no branch-specific changes, check recent commits
    if [[ -z "$changed_files" ]]; then
        changed_files=$(git log --name-only --pretty=format: -50 2>/dev/null | sort -u | grep -v '^$') || true
    fi

    if [[ -z "$changed_files" ]]; then
        echo "No file changes detected on current branch"
        return 0
    fi

    # Scan all backlog files for todo items with scope
    local candidate_files=()
    local candidate_ids=()
    local candidate_titles=()
    local candidate_matches=()

    for bf in "${BACKLOG_FILES[@]}"; do
        local backlog_path="$BACKLOG_DIR/$bf"
        [[ -f "$backlog_path" ]] || continue

        local items_json
        items_json=$(jq -c '.items[] | select((.status // "todo") == "todo" or (.status // "todo") == "in-progress") | select((.scope // []) | length > 0)' "$backlog_path" 2>/dev/null) || continue

        while IFS= read -r item; do
            [[ -z "$item" ]] && continue
            local item_id item_title
            item_id=$(echo "$item" | jq -r '.id')
            item_title=$(echo "$item" | jq -r '.title')

            # Read scope globs
            local -a globs=()
            while IFS= read -r glob; do
                globs+=("$glob")
            done < <(echo "$item" | jq -r '.scope[]' 2>/dev/null)

            [[ ${#globs[@]} -eq 0 ]] && continue

            # Check if any changed files match any scope glob
            local match_count=0
            while IFS= read -r file; do
                [[ -z "$file" ]] && continue
                for glob in "${globs[@]}"; do
                    local pattern="${glob//\*\*/*}"
                    # shellcheck disable=SC2254,SC2053
                    if [[ "$file" == $pattern ]]; then
                        match_count=$((match_count + 1))
                        break
                    fi
                done
            done <<< "$changed_files"

            if [[ "$match_count" -gt 0 ]]; then
                candidate_ids+=("$item_id")
                candidate_titles+=("$item_title")
                candidate_files+=("$bf")
                candidate_matches+=("$match_count")
            fi
        done <<< "$items_json"
    done

    if [[ ${#candidate_ids[@]} -eq 0 ]]; then
        echo "No apparently completed items detected"
        return 0
    fi

    echo "Apparently completed items (scope matches git history):"
    echo ""
    for i in "${!candidate_ids[@]}"; do
        printf "  %-12s %s  (%d file(s) match scope)\n" "${candidate_ids[$i]}" "${candidate_titles[$i]}" "${candidate_matches[$i]}"
    done
    echo ""

    if [[ "$dry_run" == "true" ]]; then
        echo "${#candidate_ids[@]} candidate(s) found (dry-run, no changes made)"
        return 0
    fi

    local marked=0
    for i in "${!candidate_ids[@]}"; do
        local cid="${candidate_ids[$i]}"
        local ctitle="${candidate_titles[$i]}"
        local cfile="${candidate_files[$i]}"

        if [[ "$auto_mark" == "true" ]]; then
            local now
            now=$(date -Iseconds 2>/dev/null || date '+%Y-%m-%dT%H:%M:%S%z')
            update_item "$cfile" "$cid" '| .status = "done" | .completedAt = $now' --arg now "$now" || {
                log_error "Failed to mark $cid done"
                continue
            }
            log_success "Marked $cid done: $ctitle"
            marked=$((marked + 1))
        else
            echo "Mark $cid done? ($ctitle)"
            read -r -p "  (y/N): " confirm
            if [[ "$confirm" == "y" || "$confirm" == "Y" ]]; then
                local now
                now=$(date -Iseconds 2>/dev/null || date '+%Y-%m-%dT%H:%M:%S%z')
                update_item "$cfile" "$cid" '| .status = "done" | .completedAt = $now' --arg now "$now" || {
                    log_error "Failed to mark $cid done"
                    continue
                }
                log_success "Marked $cid done: $ctitle"
                marked=$((marked + 1))
            else
                echo "  Skipped"
            fi
        fi
    done

    if [[ "$marked" -gt 0 ]]; then
        echo ""
        echo "Marked $marked item(s) done"
    fi
}

cmd_backlog_rm() {
    local id="${1:-}" force=false
    [[ -z "$id" ]] && { log_error "Usage: backlog rm <ID> [--force]"; return 1; }
    shift || true

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --force|-f) force=true; shift ;;
            *) log_error "Unknown option: $1"; return 1 ;;
        esac
    done

    local item
    item=$(find_item "$id") || return 1
    local title
    title=$(echo "$item" | jq -r '.title')

    local file
    file=$(resolve_backlog_file "$id") || return 1

    if [[ "$force" == "false" ]]; then
        echo "Remove $id: $title?"
        read -r -p "Confirm (y/N): " confirm
        [[ "$confirm" != "y" && "$confirm" != "Y" ]] && { echo "Cancelled"; return 0; }
    fi

    if ! remove_item "$file" "$id"; then
        log_error "Failed to remove item"
        return 1
    fi

    log_success "Removed $id: $title"
}

cmd_clean() {
    require_tool jq

    local dry_run=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dry-run) dry_run=true; shift ;;
            *) log_error "Unknown option: $1"; return 1 ;;
        esac
    done

    local feat_count=0 bug_count=0

    local backlog_file="$BACKLOG_DIR/backlog.json"
    local bugs_file="$BACKLOG_DIR/bugs.json"

    [[ -f "$backlog_file" ]] && feat_count=$(count_by_status "$backlog_file" "done")
    [[ -f "$bugs_file" ]] && bug_count=$(count_by_status "$bugs_file" "done")

    local total=$((feat_count + bug_count))

    if [[ "$total" -eq 0 ]]; then
        echo "Nothing to clean"
    elif [[ "$dry_run" == "true" ]]; then
        echo "Would remove: $feat_count features, $bug_count bugs"
    else
        if [[ "$feat_count" -gt 0 ]]; then
            remove_items_by_status "backlog.json" "done" || { log_error "Failed to clean backlog.json"; return 1; }
        fi
        if [[ "$bug_count" -gt 0 ]]; then
            remove_items_by_status "bugs.json" "done" || { log_error "Failed to clean bugs.json"; return 1; }
        fi
        echo "Cleaned $feat_count features, $bug_count bugs ($total total removed)"
    fi
}

