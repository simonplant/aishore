#   help            Show this help

set -euo pipefail

AISHORE_TMPDIR=""
AISHORE_DID_STASH=""
AISHORE_BASE_BRANCH=""
AISHORE_FEATURE_BRANCH=""
AISHORE_WORKTREE_DIR=""
LAST_AGENT_LOG=""
cleanup_exit() {
    # Clean up worktree on unexpected exit
    if [[ -n "$AISHORE_WORKTREE_DIR" ]]; then
        cd "$PROJECT_ROOT" 2>/dev/null || true
        git worktree remove "$AISHORE_WORKTREE_DIR" --force 2>/dev/null || true
        [[ -d "$AISHORE_WORKTREE_DIR" ]] && rm -rf "$AISHORE_WORKTREE_DIR" 2>/dev/null || true
        [[ -n "$AISHORE_FEATURE_BRANCH" ]] && git branch -D "$AISHORE_FEATURE_BRANCH" >/dev/null 2>&1 || true
        AISHORE_WORKTREE_DIR=""
        AISHORE_FEATURE_BRANCH=""
    elif [[ -n "$AISHORE_FEATURE_BRANCH" && -n "$AISHORE_BASE_BRANCH" ]]; then
        # Clean up feature branch on unexpected exit (stash mode)
        git checkout "$AISHORE_BASE_BRANCH" >/dev/null 2>&1 || true
        git branch -D "$AISHORE_FEATURE_BRANCH" >/dev/null 2>&1 || true
        AISHORE_FEATURE_BRANCH=""
    fi
    # Restore stashed changes on unexpected exit
    if [[ "$AISHORE_DID_STASH" == "true" ]]; then
        AISHORE_DID_STASH=""
        restore_stash || true
    fi
    [[ -n "$AISHORE_TMPDIR" && -d "$AISHORE_TMPDIR" ]] && rm -rf "$AISHORE_TMPDIR"
    return 0
}
trap cleanup_exit EXIT

ensure_tmpdir() {
    [[ -z "$AISHORE_TMPDIR" ]] && AISHORE_TMPDIR=$(mktemp -d "${TMPDIR:-/tmp}/aishore.XXXXXX")
    echo "$AISHORE_TMPDIR"
}

